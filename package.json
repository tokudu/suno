{
  "name": "tokudu-suno",
  "description": "A hosted library for TOKUDU music tracks generated by Suno (2025/2026)",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "process": "dotenvx run -f .env.encrypted -- tsx scripts/process.ts",
    "download": "dotenvx run -f .env.encrypted -- tsx scripts/download.ts --force",
    "upload": "dotenvx run -f .env.encrypted -- tsx scripts/upload.ts --force",
    "env:decrypt": "dotenvx decrypt -f .env.encrypted --stdout > .env",
    "env:encrypt": "dotenvx encrypt -f .env --stdout > .env.encrypted",
    "dev": "next dev",
    "build": "next build",
    "deploy": "dotenvx run -f .env.encrypted -- wrangler pages deploy out --project-name tokudu-suno",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@tanstack/react-table": "^8.21.3",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "embla-carousel-react": "^8.6.0",
    "next": "^14.2.29",
    "node-traktor": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.55.1",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/sharp": "^0.32.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.75.0"
  }
}
